# 1. Base da imagem - Node.jsFROM node:20-alpine# 2. Criar diretório de trabalhoWORKDIR /usr/src/app# 3. Copiar arquivos de dependências# Copiamos o prisma/ para garantir que o cliente seja gerado no buildCOPY package*.json ./COPY ./prisma ./prisma/# 4. Instalar dependênciasRUN npm install# 5. Copiar o restante do códigoCOPY . .# 6. Gerar o Prisma Client (essencial para o TypeScript reconhecer o banco)RUN npx prisma generate# 7. Build do NestJSRUN npm run build# 8. Expor a porta que o NestJS usa (padrão 3000)EXPOSE 3000# 9. Comando para rodar a aplicaçãoCMD ["npm", "run", "start:prod"]